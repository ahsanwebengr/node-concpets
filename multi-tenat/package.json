{
  "name": "multi-tenant-todo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "server": "npm run dev --workspace=packages/server",
    "client": "npm run dev --workspace=packages/client",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
